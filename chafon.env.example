# Copy to chafon.env on the gate PC / Raspberry Pi and load before running the bridge.
# Windows (PowerShell):  Get-Content chafon.env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }
# Linux/macOS:           set -a && source chafon.env && set +a

# Must match HARDWARE_SECRET in the Laravel server .env (one secret for the whole platform)
HARDWARE_SECRET=your-long-random-secret-from-server-env

# Your Digitex server scan endpoint (no trailing slash)
HARDWARE_API_URL=https://your-domain.com/api/v1/hardware/attendance/scan

# School ID — set a different value on each school's gate PC
HARDWARE_INSTITUTION_ID=3

# Optional labels
HARDWARE_DEVICE_ID=CHAFON_MAIN_GATE_01
HARDWARE_PURPOSE=attendance

# TCP port the Chafon reader pushes raw data to (must match reader Dest Port)
CHAFON_LISTEN_HOST=0.0.0.0
CHAFON_LISTEN_PORT=5000
